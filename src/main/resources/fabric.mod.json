{
	"schemaVersion": 1,
	"id": "enderpocket",
	"version": "${version}",
	"name": "EnderPocket",
	"description": "Open your real ender chest straight from the inventory screen. No chest, no commands — just a button.",
	"authors": [
		"ItsAstroDude"
	],
	"contact": {
		"sources": "https://github.com/ItsAstroDude/enderpocket"
	},
	"license": "CC0-1.0",
	"icon": "assets/enderpocket/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"dev.astro.enderpocket.EnderPocket"
		],
		"client": [
			"dev.astro.enderpocket.client.EnderPocketClient"
		]
	},
	"mixins": [
		"enderpocket.mixins.json",
		{
			"config": "enderpocket.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}
